{
  "name": "Manaprobe-graphql",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "compile": "tsc",
    "dev": "concurrently \"ts-node-dev --respawn --watch .src/graphql/*.graphql ./src/index.ts\" \"npm run generate\"",
    "start": "npm run compile && nodemon ./dist/index.js",
    "test": "jest",
    "generate": "graphql-codegen --watch 'src/graphql/schema.graphql'"
  },
  "dependencies": {
    "@apollo/datasource-rest": "^6.4.1",
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@nic-jennings/sql-datasource": "^0.0.7",
    "@parcel/watcher": "^2.5.6",
    "camelcase-keys": "^10.0.2",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-scalars": "^1.25.0",
    "graphql-tag": "^2.12.6",
    "knex": "^3.2.9",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "type-graphql": "^2.0.0-rc.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-resolvers": "^5.1.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.3",
    "@types/node": "^20.19.37",
    "concurrently": "^8.2.2",
    "jest": "^29.0.3",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.0.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "src"
    ],
    "globals": {
      "ts-jest": {
        "testRegext": "/__tests__/.*.test.ts",
        "verbose": true
      }
    }
  }
}