#!/bin/sh

# PROVIDE: manaprobe_graphql
# REQUIRE: LOGIN cleanvar
# KEYWORD: shutdown

# Put this script in /usr/local/etc/rc.d and make it executable. Then add
# "manaprobe_graphql_enable=YES" to /etc/rc.conf to enable it, i.e.:
# `cp bin/manaprobe_graphql /usr/local/etc/rc.d/manaprobe_graphql`
# `chmod a+x /usr/local/etc/rc.d/manaprobe_graphql`
# `service manaprobe_graphql enable`
# To start the service, run "service manaprobe_graphql start" or reboot the system.

PATH="/sbin:/bin:/usr/sbin:/usr/bin:/usr/local/sbin:/usr/local/bin"

. /etc/rc.subr

name="manaprobe_graphql"
workdir="/var/db/Manaprobe-graphql"
npm_cmd="/usr/local/bin/npm run dev &"

start_cmd="${name}_start"
stop_cmd=":"

: ${dummy_svcj_options:=""}

manaprobe_graphql_start()
{
       su -m www -c "cd ${workdir} && ${npm_cmd}"
}

load_rc_config $name
run_rc_command "$1"